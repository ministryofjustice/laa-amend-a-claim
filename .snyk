# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  'snyk:lic:maven:com.puppycrawl.tools:checkstyle:LGPL-2.1':
    - '*':
        reason: Build-time tool only
  'snyk:lic:maven:ch.qos.logback:logback-core:(EPL-1.0_OR_LGPL-2.1)':
    - '*':
        reason: Approved dual license
  'snyk:lic:maven:ch.qos.logback:logback-classic:(EPL-1.0_OR_LGPL-2.1)':
    - '*':
        reason: Approved license
  'snyk:lic:maven:org.eclipse.sisu:org.eclipse.sisu.inject:EPL-1.0':
    - '*':
        reason: Approved license
  'snyk:lic:maven:net.sf.saxon:Saxon-HE:MPL-2.0':
    - '*':
        reason: Build-time tool only (used by checkstyle)
  'snyk:lic:maven:com.github.spotbugs:spotbugs-annotations:LGPL-2.1':
    - '*':
        reason: Approved license

  SNYK-JAVA-ORGSPRINGFRAMEWORK-17253520:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-IOMICROMETER-17260885:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17254527:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17254116:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17254544:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17255206:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17253311:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17254115:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17254528:
      - '*':
          reason: Waiting for Spring to catch up with fix
  SNYK-JAVA-ORGSPRINGFRAMEWORK-17254543:
      - '*':
          reason: Waiting for Spring to catch up with fix
patch: {}
exclude:
  global:
