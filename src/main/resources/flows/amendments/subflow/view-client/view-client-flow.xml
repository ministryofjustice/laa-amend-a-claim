<?xml version="1.0" encoding="UTF-8"?>
<flow xmlns="http://www.springframework.org/schema/webflow"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.springframework.org/schema/webflow http://www.springframework.org/schema/webflow/spring-webflow.xsd"
  start-state="decision-check-feature-flag">

  <input name="submissionId" type="java.util.UUID"/>
  <input name="claimId" type="java.util.UUID"/>
  <input name="clientView"/>
  <input name="client1Form"/>

  <decision-state id="decision-check-feature-flag">
    <if test="featureFlagsConfig.getIsClaimAmendmentEnabled()"
      then="view-client"
      else="not-found"/>
  </decision-state>

  <view-state id="view-client" view="amendments/view-client">
    <transition on="change" to="end-state-change"/>
  </view-state>

  <end-state id="not-found" view="redirect:/not-found"/>

  <end-state id="end-state-change"/>
</flow>