<?xml version="1.0" encoding="UTF-8"?>
<flow xmlns="http://www.springframework.org/schema/webflow"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.springframework.org/schema/webflow
      http://www.springframework.org/schema/webflow/spring-webflow.xsd">

  <input name="submissionId" type="java.util.UUID"/>
  <input name="claimId" type="java.util.UUID"/>
  <!-- TODO: 404 when these are missing? -->

  <on-start>
    <evaluate
      expression="claimClientHandler.loadClaim(externalContext, submissionId, claimId)"
      result="flowScope.clientView"/>
    <evaluate
      expression="claimClientHandler.populateClient1Form(clientView)"
      result="flowScope.client1Form"/>
    <evaluate
      expression="claimClientHandler.populateClient2Form(clientView)"
      result="flowScope.client2Form"/>
  </on-start>

  <subflow-state id="view-client" subflow="amendments/subflow/view-client">
    <input name="submissionId" value="submissionId"/>
    <input name="claimId" value="claimId"/>
    <input name="clientView" value="clientView"/>
    <input name="client1Form" value="client1Form"/>
    <transition on="end-state-change" to="amend-client-1"/>
  </subflow-state>

  <subflow-state id="amend-client-1" subflow="amendments/subflow/amend-client-1">
    <input name="submissionId" value="submissionId"/>
    <input name="claimId" value="claimId"/>
    <input name="clientView" value="clientView"/>
    <input name="client1Form" value="client1Form"/>
    <transition on="end-state-continue" to="view-client"/>
  </subflow-state>

  <end-state id="end-state-end"/>

</flow>
